{
  "name": "dvp-standalone-application",
  "homepage": "https://dvpeasy.trade",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "analyze": "vite-bundle-visualizer",
    "build": "npm run sync-icons && npm run lint && tsc && vite build",
    "build:analyze": "npm run sync-icons && npm run lint && tsc && vite build --mode analyze",
    "dev": "vite",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pretest:e2e:playwright": "npx playwright install chromium --with-deps",
    "pretest:e2e:synpress": "npx synpress tests/wallet-setup --debug --headless",
    "preview": "vite preview",
    "sync-icons": "node scripts/sync-icons.js",
    "test:e2e": "npx playwright test",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:report": "npx playwright show-report",
    "test:e2e:ui": "npx playwright test --ui"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "1.7.18",
    "@reown/appkit": "^1.8.4",
    "@reown/appkit-adapter-wagmi": "^1.8.4",
    "@tanstack/react-query": "^5.51.23",
    "@types/flatpickr": "^3.0.2",
    "clsx": "2.1.0",
    "connect-history-api-fallback": "^2.0.0",
    "cryptocurrency-icons": "^0.18.1",
    "d3": "^7.8.5",
    "flatpickr": "^4.6.13",
    "flyonui": "2.4.0",
    "lucide-react": "0.344.0",
    "postcss": "^8.4.49",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hot-toast": "2.4.1",
    "react-router-dom": "6.22.1",
    "tailwind-merge": "2.2.1",
    "tailwindcss": "^3.4.17",
    "use-debounce": "10.0.0",
    "viem": "^2.19.8",
    "wagmi": "^2.12.2",
    "zod": "^4.1.1"
  },
  "devDependencies": {
    "@playwright/test": "1.48.2",
    "@synthetixio/synpress": "^4.1.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.1.0",
    "@types/react": "18.2.55",
    "@types/react-dom": "18.2.19",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "@vitejs/plugin-react": "4.2.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-react-refresh": "0.4.5",
    "typescript": "5.9.2",
    "vite": "4.5.2",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-svgr": "^4.5.0"
  },
  "engines": {
    "npm": ">=11.3.0 <12.0.0",
    "node": ">=23.11.0 <24.0.0"
  },
  "packageManager": "yarn@4.9.4+sha512.7b1cb0b62abba6a537b3a2ce00811a843bea02bcf53138581a6ae5b1bf563f734872bd47de49ce32a9ca9dcaff995aa789577ffb16811da7c603dcf69e73750b"
}
